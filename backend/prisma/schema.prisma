generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  email         String   @unique
  password      String
  role          Role     @default(KASIR)
  name          String
  outlet        String?
  phone         String?
  shift         String?
  salary        Float?
  twoFactorSecret String?
  twoFactorEnabled Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  transactions  Transaction[]
  courier       Courier?
  pickupDeliveries PickupDelivery[]
  activityLogs  ActivityLog[]
  pushSubscription PushSubscription?
}

model Customer {
  id            String         @id @default(uuid())
  name          String
  phone         String?
  address       String?
  email         String?
  totalSpent    Float          @default(0)
  totalOrders   Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  transactions  Transaction[]
  membership    Membership?
  redeemedVouchers RedeemedVoucher[]
  pickupDeliveries PickupDelivery[]  // RELASI KE PICKUP
  ratings       Rating[]          // RELASI KE RATING
}

model Transaction {
  id              String        @id @default(uuid())
  invoiceCode     String        @unique
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id])
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  weight          Float?
  itemCount       Int?
  serviceType     ServiceType
  pricePerUnit    Float
  subtotal        Float
  discount        Float         @default(0)
  tax             Float         @default(0)
  total           Float
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  paymentMethod   PaymentMethod?
  pickupDate      DateTime?
  completedDate   DateTime?
  notes           String?
  items           Json
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  pickupDelivery  PickupDelivery?  // RELASI KE PICKUP
  rating        Rating?           // RELASI KE RATING
}

model Device {
  id              String        @id @default(uuid())
  name            String
  type            DeviceType
  status          DeviceStatus  @default(OFFLINE)
  cycle           String
  timeRemaining   Int           @default(0)
  temperature     Int           @default(0)
  currentLoad     Float         @default(0)
  lastMaintenance DateTime
  outletId        String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  logs            DeviceLog[]
}

model DeviceLog {
  id        String   @id @default(uuid())
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id])
  action    String
  duration  Int
  timestamp DateTime @default(now())
}

model OperationalCost {
  id          String   @id @default(uuid())
  category    CostCategory
  description String
  amount      Float
  date        DateTime @default(now())
  outletId    String
  createdAt   DateTime @default(now())
}

model WABroadcast {
  id          String   @id @default(uuid())
  message     String
  targetCount Int
  sentCount   Int
  status      String
  createdAt   DateTime @default(now())
  createdBy   String
}

model WALog {
  id          String   @id @default(uuid())
  phoneNumber String
  message     String
  status      String
  sentAt      DateTime @default(now())
  broadcastId String?
}

model ChatbotConfig {
  id          String   @id @default(uuid())
  enabled     Boolean  @default(true)
  welcomeMsg  String
  autoReply   Json?
  outletId    String
  updatedAt   DateTime @updatedAt
}

model ChatbotLog {
  id          String   @id @default(uuid())
  phoneNumber String
  message     String
  reply       String
  intent      String
  createdAt   DateTime @default(now())
}

model Membership {
  id            String   @id @default(uuid())
  customerId    String   @unique
  customer      Customer @relation(fields: [customerId], references: [id])
  level         MemberLevel @default(SILVER)
  points        Int      @default(0)
  totalSpent    Float    @default(0)
  birthday      DateTime?
  joinedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt
  transactions  MembershipTransaction[]
}

model MembershipTransaction {
  id            String   @id @default(uuid())
  membershipId  String
  membership    Membership @relation(fields: [membershipId], references: [id])
  type          String
  points        Int
  description   String
  createdAt     DateTime @default(now())
}

model Voucher {
  id            String         @id @default(uuid())
  code          String         @unique
  discountType  String
  discountValue Float
  minSpend      Float?
  maxDiscount   Float?
  validFrom     DateTime
  validTo       DateTime
  isActive      Boolean        @default(true)
  usedCount     Int            @default(0)
  maxUses       Int?
  createdAt     DateTime       @default(now())
  redemptions   RedeemedVoucher[]
}

model RedeemedVoucher {
  id            String   @id @default(uuid())
  voucherId     String
  voucher       Voucher  @relation(fields: [voucherId], references: [id])
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  transactionId String?
  redeemedAt    DateTime @default(now())
}

// ============ PICKUP & DELIVERY ============

model PickupDelivery {
  id            String   @id @default(uuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  transactionId String?  @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  address       String
  latitude      Float?
  longitude     Float?
  pickupDate    DateTime
  deliveryDate  DateTime?
  status        PickupStatus @default(PENDING)
  courierId     String?
  courier       User?    @relation(fields: [courierId], references: [id])
  notes         String?
  distance      Float?
  deliveryFee   Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Courier {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  vehicle       String
  plateNumber   String
  isAvailable   Boolean  @default(true)
  rating        Float    @default(0)
  totalDeliveries Int    @default(0)
  createdAt     DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   String?
  ipAddress String?
  timestamp DateTime @default(now())
}

model PushSubscription {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  subscription String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Rating {
  id            String   @id @default(uuid())
  transactionId String   @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  rating        Int
  review        String?
  response      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Inventory {
  id          String   @id @default(uuid())
  name        String
  category    String
  stock       Int      @default(0)
  minStock    Int      @default(10)
  unit        String   @default("kg")
  price       Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Outlet {
  id        String   @id @default(uuid())
  name      String
  address   String
  phone     String?
  manager   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model License {
  id           String   @id @default(uuid())
  licenseKey   String   @unique
  packageType  String
  customerName String
  hardwareId   String
  expiryDate   DateTime
  isActive     Boolean  @default(true)
  activatedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Role {
  ADMIN
  KASIR
  OWNER
}

enum ServiceType {
  KILOAN
  SATUAN
  EXPRESS
  BEDCOVER
  SEPATU
}

enum OrderStatus {
  PENDING
  PROGRESS
  READY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIAL
}

enum PaymentMethod {
  CASH
  TRANSFER
  QRIS
  DEBIT
}

enum DeviceType {
  WASHER
  DRYER
}

enum DeviceStatus {
  ONLINE
  BUSY
  OFFLINE
  MAINTENANCE
}

enum MemberLevel {
  SILVER
  GOLD
  PLATINUM
}

enum PickupStatus {
  PENDING
  ASSIGNED
  PICKED
  DELIVERED
  CANCELLED
}

enum CostCategory {
  ELECTRICITY
  WATER
  DETERGENT
  FABRIC_SOFTENER
  SALARY
  RENT
  MAINTENANCE
  OTHER
}